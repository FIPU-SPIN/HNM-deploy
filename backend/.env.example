# Copy to .env and fill in. The backend reads these via dotenv.
# Local MongoDB (installed on this server). For Atlas use mongodb+srv://...
MONGO_URI=mongodb://127.0.0.1:27017/Naglasci
# Secret used to sign JWT auth tokens. Generate one with:
#   node -e "console.log(require(\"crypto\").randomBytes(48).toString(\"hex\"))"
JWT_SECRET=replace-me-with-a-long-random-string
# Port the Express API listens on
PORT=5000
